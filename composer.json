{
    "name": "kungfufafa/mekaya-theme",
    "description": "Mekaya — a custom Filament v4/v5 admin panel appshell (sidebar, topbar, theme, Blade components).",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "apriansyahrs"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0 || ^5.0",
        "livewire/livewire": "^3.5 || ^4.0",
        "mckenziearts/blade-untitledui-icons": "^1.5"
    },
    "autoload": {
        "psr-4": {
            "Apriansyahrs\\MekayaTheme\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Apriansyahrs\\MekayaTheme\\MekayaServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
